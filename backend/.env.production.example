DJANGO_SECRET_KEY=replace-with-strong-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.your-domain.com
WEBSITE_URL=https://api.your-domain.com
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_DOMAIN=your-domain.com
AUTH_COOKIE_PATH=/
AUTH_REFRESH_COOKIE_NAME=refresh_token

DB_ENGINE=django.db.backends.postgresql
DB_NAME=project_manager
DB_USER=pm_user
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=120
DB_CONNECT_TIMEOUT=10

THROTTLE_ANON=30/minute
THROTTLE_USER=120/minute
SECURE_SSL_REDIRECT=True
