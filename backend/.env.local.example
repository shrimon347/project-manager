DJANGO_SECRET_KEY=replace-with-local-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Public API base URL (emails, absolute links). Match the hostname you use in the browser for the API
# when testing with Next.js — e.g. http://localhost:8000 if NEXT_PUBLIC_API_URL uses localhost.
WEBSITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# HttpOnly refresh cookie (industry pattern: refresh never in JSON bodies).
# AUTH_COOKIE_DOMAIN: leave empty for localhost so the cookie is host-only for the API host.
# Do not set AUTH_COOKIE_DOMAIN=localhost unless you know your setup; empty is the usual dev default.
# Production (API on api.example.com, SPA on app.example.com): use SameSite=None, Secure=True, and a shared parent domain if applicable.
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_REFRESH_COOKIE_NAME=refresh_token

# No quotes around the list. Origins must include your Next dev URL(s).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_ENGINE=django.db.backends.postgresql
DB_NAME=project_manager_local
DB_USER=postgres
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=10

THROTTLE_ANON=300/minute
THROTTLE_USER=1000/minute
